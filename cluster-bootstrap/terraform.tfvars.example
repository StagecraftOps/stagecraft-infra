# Nothing sensitive lives here anymore — every credential moved to stage 1's
# terraform.tfvars (Secrets Manager), synced into the cluster by the External
# Secrets Operator this stage installs. Only override these if you changed the
# corresponding value in stage 1.

# aws_region               = "us-east-1"
# namespace                = "stagecraft"
# eso_namespace            = "external-secrets"
# eso_service_account_name = "external-secrets"
